{
  "name": "@multimarcdown/bulk-media-import",
  "version": "0.1.0",
  "type": "module",
  "description": "End-to-end bulk media import pipeline (S3-compatible source → Cloudflare R2 + D1). 41 files/sec sustained via AWS SDK direct PUT. Cross-platform CLI.",
  "license": "MIT",
  "bin": {
    "bulk-media-fast-upload": "scripts/fast_upload.mjs",
    "bulk-media-process-bundle": "scripts/process_bundle.mjs"
  },
  "scripts": {
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "peerDependencies": {
    "wrangler": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "wrangler": { "optional": false }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "scripts/",
    "contracts/",
    "docs/",
    "manifest.yaml",
    "README.md"
  ],
  "keywords": [
    "cloudflare",
    "r2",
    "d1",
    "s3",
    "bulk-import",
    "media",
    "migration",
    "etl",
    "aws-sdk"
  ]
}

{
  "name": "@multimarcdown/local-agent-terminal",
  "version": "0.1.0",
  "type": "module",
  "description": "Persistent browser terminal backed by node-pty, with an optional Cloudflare relay and pluggable launch profiles (Claude Code, shells, dev servers).",
  "exports": {
    "./frontend": "./dist/frontend/index.js",
    "./backend": "./dist/backend/index.js",
    "./cloudflare": "./dist/cloudflare/index.js",
    "./contracts": "./dist/contracts/protocol.js",
    "./contracts/config": "./dist/contracts/config.js"
  },
  "scripts": {
    "build": "tsc -b",
    "daemon": "node dist/backend/pty-bridge-daemon.js",
    "verify": "node --loader ts-node/esm scripts/verify.ts"
  },
  "dependencies": {
    "@multimarcdown/core": "*",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@xterm/xterm": { "optional": true },
    "@xterm/addon-fit": { "optional": true },
    "@xterm/addon-web-links": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.0"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "shared.ts",
    "index.ts",
    "tiktok/**/*.ts",
    "instagram/**/*.ts",
    "facebook/**/*.ts",
    "pinterest/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright/.auth", "test-results", "playwright-report"]
}
